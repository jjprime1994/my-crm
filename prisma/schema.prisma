generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  password          String
  role              Role                @default(SALESPERSON)
  claimLimit        Int                 @default(5)
  newLeadThreshold  Int                 @default(0)
  coveredStates     String[]            @default([])
  isDefaultTeam     Boolean             @default(false)
  autoAssign        Boolean             @default(false)
  managerId         String?
  manager           User?               @relation("TeamMembers", fields: [managerId], references: [id])
  teamMembers       User[]              @relation("TeamMembers")
  leads             Lead[]              @relation("AssignedLeads")
  notes             LeadNote[]
  statusChanges     LeadStatusHistory[]
  suggestions       Suggestion[]
  pushSubscriptions PushSubscription[]
  claimedLeads      Lead[]              @relation("ClaimedLeads")
  assignmentsMade   LeadAssignmentLog[] @relation("AssignedByLogs")
  assignmentsReceived LeadAssignmentLog[] @relation("AssignedToLogs")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEAM_LEADER
  SALESPERSON
}

model Lead {
  id               String              @id @default(cuid())
  metaLeadId       String?             @unique
  formId           String?
  adId             String?
  adName           String?
  campaignId       String?
  campaignName     String?
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  branch           String?
  source           String              @default("META")
  firstContactedAt DateTime?
  status           LeadStatus          @default(NEW)
  assignedTo       User?               @relation("AssignedLeads", fields: [assignedToId], references: [id])
  assignedToId     String?
  claimedAt        DateTime?
  claimedById      String?
  claimedBy        User?               @relation("ClaimedLeads", fields: [claimedById], references: [id], onDelete: SetNull)
  followUpAt       DateTime?
  isDuplicate      Boolean             @default(false)
  notes            LeadNote[]
  statusHistory    LeadStatusHistory[]
  assignmentLogs   LeadAssignmentLog[]
  rawData          Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([assignedToId])
  @@index([assignedToId, status])
  @@index([assignedToId, claimedAt])
  @@index([assignedToId, followUpAt])
  @@index([claimedById, claimedAt])
  @@index([status])
  @@index([isDuplicate, assignedToId])
  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@index([branch])
  @@index([adName])
}

model AdRoute {
  id        String   @id @default(cuid())
  adId      String?
  adName    String   @unique
  teamIds   String[]
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  CLOSED_WON
  CLOSED_LOST
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model LeadNote {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  content   String
  createdAt DateTime @default(now())
}

model Suggestion {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        String   @default("SUGGESTION")
  title       String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StateRoute {
  id                String   @id @default(cuid())
  state             String   @unique
  userIds           String[]
  lastAssignedIndex Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LeadStatusHistory {
  id          String      @id @default(cuid())
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  from        LeadStatus?
  to          LeadStatus
  changedBy   User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedById String?
  createdAt   DateTime    @default(now())

  @@index([leadId])
}

model LeadAssignmentLog {
  id           String   @id @default(cuid())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       String
  assignedTo   User?    @relation("AssignedToLogs", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedBy   User?    @relation("AssignedByLogs", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedById String?
  source       String   @default("ADMIN")
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([assignedToId])
  @@index([assignedById])
}
